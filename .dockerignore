apps/gitlock_core/deps

# Where third-party dependencies like ExDoc output generated docs.
apps/gitlock_core/doc

# Ignore .fetch files in case you like to edit your project deps locally.
apps/gitlock_core/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
apps/gitlock_core/**/erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
apps/gitlock_core/**/*.ez

# Ignore package tarball (built via "mix hex.build").
apps/gitlock_core/**/gitlock_holmes_core-*.tar

# Temporary files, for example, from tests.
apps/gitlock_core/tmp


apps/gitlock_core/**/.DS_Store

# flyctl launch added from apps/gitlock_phx/.gitignore
# The directory Mix will write compiled artifacts to.
apps/gitlock_phx/_build

# If you run "mix test --cover", coverage assets end up here.
apps/gitlock_phx/cover

# The directory Mix downloads your dependencies sources to.
apps/gitlock_phx/deps

# Where 3rd-party dependencies like ExDoc output generated docs.
apps/gitlock_phx/doc

# Ignore .fetch files in case you like to edit your project deps locally.
apps/gitlock_phx/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
apps/gitlock_phx/**/erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
apps/gitlock_phx/**/*.ez

# Temporary files, for example, from tests.
apps/gitlock_phx/tmp

# Ignore package tarball (built via "mix hex.build").
apps/gitlock_phx/**/gitlock_phx-*.tar

# Ignore assets that are produced by build tools.
apps/gitlock_phx/priv/static/assets

# Ignore digested assets cache.
apps/gitlock_phx/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
apps/gitlock_phx/**/npm-debug.log
apps/gitlock_phx/assets/node_modules

fly.toml
